generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum StreamRunStatus {
  queued
  running
  succeeded
  failed
}

enum StreamSource {
  openalex
}

enum ScoringProvider {
  openai
  anthropic
}

model Stream {
  id        String      @id @default(cuid())
  name      String
  query     String
  source    StreamSource @default(openalex)
  maxObjects Int         @default(100)
  isActive  Boolean     @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  runs      StreamRun[]
  runObjects StreamRunObject[]

  @@map("streams")
}

model StreamRun {
  id            String   @id @default(cuid())
  streamId       String
  status         StreamRunStatus @default(queued)
  startedAt      DateTime @default(now())
  finishedAt     DateTime?
  processedCount Int      @default(0)
  insertedCount  Int      @default(0)
  updatedCount   Int      @default(0)
  failedCount    Int      @default(0)
  failureReason  String?
  stream         Stream   @relation(fields: [streamId], references: [id], onDelete: Cascade)
  objects        StreamRunObject[]

  @@index([streamId])
  @@index([status])
  @@index([streamId, status, startedAt(sort: Desc)])
  @@map("stream_runs")
}

model StreamRunObject {
  id          String         @id @default(cuid())
  streamRunId String
  streamId    String
  objectId    String
  createdAt   DateTime       @default(now())
  streamRun   StreamRun      @relation(fields: [streamRunId], references: [id], onDelete: Cascade)
  stream      Stream         @relation(fields: [streamId], references: [id], onDelete: Cascade)
  object      ResearchObject @relation(fields: [objectId], references: [id], onDelete: Cascade)

  @@unique([streamRunId, objectId])
  @@index([streamId, objectId])
  @@index([objectId])
  @@map("stream_run_objects")
}

model ResearchObject {
  id           String               @id @default(cuid())
  externalId   String
  source       String
  title        String
  abstract     String?
  sourceMetadata Json?
  publishedAt  DateTime?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  objectLinks  ObjectEntity[]
  scores       ObjectScore[]
  pipelineCard ObjectPipelineCard[]
  streamRuns   StreamRunObject[]
  note         ObjectNote?

  @@unique([externalId, source])
  @@index([publishedAt])
  @@map("research_objects")
}

model Entity {
  id          String         @id @default(cuid())
  name        String
  kind        String
  externalId  String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  objectLinks ObjectEntity[]
  scores      EntityScore[]

  @@unique([kind, name])
  @@index([externalId])
  @@map("entities")
}

model ObjectEntity {
  id        String         @id @default(cuid())
  objectId  String
  entityId  String
  role      String
  position  Int?
  createdAt DateTime       @default(now())
  object    ResearchObject @relation(fields: [objectId], references: [id], onDelete: Cascade)
  entity    Entity         @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@unique([objectId, entityId, role])
  @@index([entityId])
  @@index([objectId])
  @@map("object_entities")
}

model Dimension {
  id        String        @id @default(cuid())
  name      String
  prompt    String
  provider  ScoringProvider
  model     String
  isActive  Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  scores    ObjectScore[]
  foldups   EntityScore[]

  @@unique([name])
  @@map("dimensions")
}

model ObjectScore {
  id          String         @id @default(cuid())
  dimensionId String
  objectId    String
  value       Float
  explanation String
  metadata    Json?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  dimension   Dimension      @relation(fields: [dimensionId], references: [id], onDelete: Cascade)
  object      ResearchObject @relation(fields: [objectId], references: [id], onDelete: Cascade)

  @@unique([dimensionId, objectId])
  @@index([objectId])
  @@index([dimensionId])
  @@map("object_scores")
}

model EntityScore {
  id          String    @id @default(cuid())
  dimensionId String
  entityId    String
  value       Float
  explanation String
  metadata    Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  dimension   Dimension @relation(fields: [dimensionId], references: [id], onDelete: Cascade)
  entity      Entity    @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@unique([dimensionId, entityId])
  @@index([entityId])
  @@map("entity_scores")
}

model Pipeline {
  id          String               @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  stages      PipelineStage[]
  cards       ObjectPipelineCard[]

  @@map("pipelines")
}

model PipelineStage {
  id         String               @id @default(cuid())
  pipelineId String
  name       String
  position   Int
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt
  pipeline   Pipeline             @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  cards      ObjectPipelineCard[]

  @@unique([pipelineId, position])
  @@index([pipelineId])
  @@map("pipeline_stages")
}

model ObjectPipelineCard {
  id         String         @id @default(cuid())
  pipelineId String
  stageId    String
  objectId   String
  position   Int
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  pipeline   Pipeline       @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  stage      PipelineStage  @relation(fields: [stageId], references: [id], onDelete: Cascade)
  object     ResearchObject @relation(fields: [objectId], references: [id], onDelete: Cascade)

  @@unique([pipelineId, objectId])
  @@index([stageId, position])
  @@index([pipelineId, stageId, position])
  @@map("object_pipeline_cards")
}

model ApiKey {
  id           String    @id @default(cuid())
  provider     ScoringProvider
  encryptedKey String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  revokedAt    DateTime?

  @@unique([provider])
  @@map("api_keys")
}

model FeedSavedView {
  id         String   @id @default(cuid())
  name       String
  definition Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([name])
  @@index([updatedAt(sort: Desc)])
  @@map("feed_saved_views")
}

model WorkspacePreference {
  id        String   @id @default(cuid())
  key       String
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([key])
  @@index([updatedAt(sort: Desc)])
  @@map("workspace_preferences")
}

model ObjectNote {
  id        String         @id @default(cuid())
  objectId  String
  document  Json
  revision  Int            @default(0)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  object    ResearchObject @relation(fields: [objectId], references: [id], onDelete: Cascade)

  @@unique([objectId])
  @@index([updatedAt(sort: Desc)])
  @@map("object_notes")
}
