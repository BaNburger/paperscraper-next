{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AgentLintRule",
  "type": "object",
  "required": [
    "id",
    "description",
    "severity",
    "scope",
    "matcher",
    "autofix",
    "allowlistable"
  ],
  "properties": {
    "id": { "type": "string" },
    "description": { "type": "string" },
    "severity": { "type": "string", "enum": ["error", "warning"] },
    "scope": { "type": "string" },
    "matcher": { "type": "string" },
    "autofix": { "type": "boolean" },
    "allowlistable": { "type": "boolean" }
  },
  "additionalProperties": false
}
