{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PhaseMeta",
  "type": "object",
  "required": [
    "phase_id",
    "stage",
    "depends_on",
    "owners",
    "status",
    "entry_gate",
    "exit_gate"
  ],
  "properties": {
    "phase_id": { "type": "string" },
    "stage": { "type": "string" },
    "depends_on": {
      "type": "array",
      "items": { "type": "string" }
    },
    "owners": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "status": { "type": "string" },
    "entry_gate": { "type": "string" },
    "exit_gate": { "type": "string" }
  },
  "additionalProperties": false
}
